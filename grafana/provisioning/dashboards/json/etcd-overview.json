        {
          "expr": "histogram_quantile(0.50, sum(rate(etcd_disk_backend_commit_duration_seconds_bucket{job=\"etcd\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ]
    },
